# =============================================================================
# duoVoiceCoach — .gitignore
# =============================================================================

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST

# --- uv / virtualenv ---------------------------------------------------------
.venv/
.python-version

# --- Test / coverage ---------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.tox/

# --- Whisper model cache -----------------------------------------------------
# Downloaded on first run; not committed
~/.cache/whisper/
.whisper_cache/

# --- Audio session recordings ------------------------------------------------
# Checked-in fixture audio (tests/fixtures/) IS committed; live recordings are not
sessions/
recordings/
*.wav
!tests/fixtures/*.wav

# --- Environment -------------------------------------------------------------
.env
# .env.example is committed intentionally

# --- Frontend (React/Vite) ---------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# --- Docker data volumes ------------------------------------------------------
data/

# --- OS / editor -------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Ruff --------------------------------------------------------------------
.ruff_cache/

# --- mypy --------------------------------------------------------------------
.mypy_cache/
.dmypy.json
