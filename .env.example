# =============================================================================
# duoVoiceCoach — Project Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# =============================================================================

# --- AI Provider Keys --------------------------------------------------------
# Required for Phase 2+ (Claude coaching responses)
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for all AI calls (chat, translation, flashcards, pronunciation).
# Default: claude-sonnet-4-6
# DVC_CLAUDE_MODEL=claude-sonnet-4-6

# Required when OpenAI is selected as the AI provider or STT_PROVIDER=openai.
OPENAI_API_KEY=

# Optional: override the default OpenAI chat model exposed in the UI.
# Default: gpt-4.1-mini
# DVC_OPENAI_MODEL=gpt-4.1-mini

# Required when Google Gemini is selected as the AI provider.
GOOGLE_API_KEY=

# Optional: override the default Google Gemini model exposed in the UI.
# Default: gemini-2.5-flash
# DVC_GOOGLE_MODEL=gemini-2.5-flash

# Required when DeepSeek is selected as the AI provider.
DEEPSEEK_API_KEY=

# Optional: override the default DeepSeek model exposed in the UI.
# Default: deepseek-chat
# DVC_DEEPSEEK_MODEL=deepseek-chat

# Required when Groq is selected as the AI provider.
GROQ_API_KEY=

# Optional: override the default Groq model exposed in the UI.
# Default: llama-3.3-70b-versatile
# DVC_GROQ_MODEL=llama-3.3-70b-versatile

# Optional: maximum tokens per Claude response (applies to all endpoints).
# Default: 1024
# DVC_CLAUDE_MAX_TOKENS=1024

# Optional: number of recent conversation turn pairs to include in each Claude request.
# Older turns are dropped. Set lower to reduce token cost on long sessions.
# Default: 10
# DVC_CONTEXT_TURNS=10

# --- Application -------------------------------------------------------------
# Required in any environment. Must be a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
DVC_SESSION_SECRET=

# Optional: override local persistence directory.
# Default: ~/.duoVoiceCoach
# DVC_DATA_DIR=~/.duoVoiceCoach

# Optional: retain uploaded user audio WAV files with persisted sessions.
# Default: false. Transcripts and corrections are still saved when false.
# DVC_SAVE_AUDIO=false

# --- Whisper (Phase 1+) ------------------------------------------------------
# Local Whisper runs without any API key (MVP default).
# Model size: base (recommended), tiny, small, medium, large
# Default: base
# WHISPER_MODEL=base

# --- TTS (Phase 6+) ----------------------------------------------------------
# Required when ElevenLabs TTS is enabled (tts_provider=elevenlabs in session config).
# Leave blank to use browser speechSynthesis (default).
# Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# Optional: override the default ElevenLabs model.
# Default: eleven_multilingual_v2 (recommended for Spanish)
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- STT Provider (Phase 10+) ------------------------------------------------
# Options: local (default, uses local Whisper), openai (uses OpenAI Whisper API)
# Default: local
# STT_PROVIDER=local

# --- Basic Auth (optional) ---------------------------------------------------
# When both vars are set, all routes require HTTP Basic Auth.
# If either is absent, auth is disabled (safe for local dev).
# DVC_BASIC_AUTH_USER=
# DVC_BASIC_AUTH_PASS=
