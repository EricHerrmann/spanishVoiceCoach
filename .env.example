# =============================================================================
# duoVoiceCoach — Project Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# =============================================================================

# --- AI Provider Keys --------------------------------------------------------
# Required for Phase 2+ (Claude coaching responses)
ANTHROPIC_API_KEY=

# Optional: override the default Claude model
# Default: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Application -------------------------------------------------------------
# Required in any environment. Must be a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
DVC_SESSION_SECRET=

# Optional: override local persistence directory.
# Default: ~/.duoVoiceCoach
# DVC_DATA_DIR=~/.duoVoiceCoach

# Optional: retain uploaded user audio WAV files with persisted sessions.
# Default: false. Transcripts and corrections are still saved when false.
# DVC_SAVE_AUDIO=false

# --- Whisper (Phase 1+) ------------------------------------------------------
# Local Whisper runs without any API key (MVP default).
# Model size: base (recommended), tiny, small, medium, large
# Default: base
# WHISPER_MODEL=base

# --- TTS (Phase 6+) ----------------------------------------------------------
# Required when ElevenLabs TTS is enabled (tts_provider=elevenlabs in session config).
# Leave blank to use browser speechSynthesis (default).
# Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# Optional: override the default ElevenLabs model.
# Default: eleven_multilingual_v2 (recommended for Spanish)
# ELEVENLABS_MODEL=eleven_multilingual_v2
