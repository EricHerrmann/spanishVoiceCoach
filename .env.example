# =============================================================================
# Kanban Studio — Project Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# PRODUCTION WARNING: See docs/codeReview.md § Phase 15 before deploying.
# Never copy a local .env directly into a production environment — always
# create a scoped, deployment-specific secrets file containing only the
# variables that deployment needs.
# =============================================================================

# --- AI Model Keys -----------------------------------------------------------
# Active provider key(s). Only the key(s) for the model you are currently
# using need to be set; unused keys can be left blank.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# --- Model Selection ---------------------------------------------------------
# Controls which OpenAI-compatible model the board assistant uses.
# Default (if unset): gpt-4.1-mini
# As additional providers are wired in, add their model selectors here.

OPENAI_MODEL=gpt-4.1-mini
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GOOGLE_MODEL=gemini-2.0-flash
# DEEPSEEK_MODEL=deepseek-chat
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Application -------------------------------------------------------------

# Required in any environment. Must be a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# PRODUCTION: if unset, the app will refuse to start.
PM_SESSION_SECRET=

# Optional: override the SQLite database file path.
# Default: data/pm.sqlite3 (relative to project root)
# PM_DB_PATH=

# Optional: set to "true" to require HTTPS-only session cookies.
# Must be "true" in any internet-facing deployment.
# Default: false (local dev)
# PM_HTTPS_ONLY=false
